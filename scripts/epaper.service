[Unit]
Description=ePaper Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=epaper
Group=epaper
WorkingDirectory=/opt/ePaperService
Environment=EPAPER_DATA_DIR=/var/lib/epaper-service
Environment=EPAPER_ADMIN_TOKEN=change-this-admin-token
ExecStart=/opt/ePaperService/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
